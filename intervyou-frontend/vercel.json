{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.intervyou.uk" }],
      "destination": "https://intervyou.uk/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://13.51.162.43/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

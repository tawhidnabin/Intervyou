[Unit]
Description=IntervYou Flask Backend
After=network.target ollama.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/Intervyou/backend
Environment="PATH=/home/ubuntu/Intervyou/venv/bin:/usr/bin"
ExecStart=/home/ubuntu/Intervyou/venv/bin/gunicorn --bind 127.0.0.1:5000 --workers 2 --timeout 120 "app:create_app()"
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
